{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Pt.Okx.Sdk.csproj"
          ],
          "src": "..",
          "exclude": [
            "**/obj/**",
            "**/bin/**"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "PlatinumTrade SDK API Reference",
      "_enableSearch": "true"
    },
    "template": [
      "default"
    ]
  }
}
